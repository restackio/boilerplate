{
  "name": "@boilerplate/database",
  "version": "0.0.1",
  "private": true,
  "description": "Database migrations and admin seed for the boilerplate",
  "scripts": {
    "migrate": "bash scripts/migrate.sh",
    "admin:insert": "bash scripts/insert-admin.sh",
    "admin:reset": "bash scripts/reset-admin.sh",
    "postgres:connect": "psql $DATABASE_URL",
    "postinstall": "mkdir -p node_modules"
  },
  "files": [
    "migrations/",
    "admin/",
    "scripts/"
  ]
}
