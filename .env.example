# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boilerplate_postgres
CLICKHOUSE_URL=http://clickhouse:clickhouse@localhost:8123/boilerplate_clickhouse
COCKROACHDB_URL=postgresql://root@localhost:26257/boilerplate_cockroachdb?sslmode=disable

# Password Encryption
PASSWORD_SALT=HVrL59iskZ5fQ0qO8yNM5ux2EWDYTpGFC6BtafYRZ2c

# Password reset email (Resend). Get API key at https://resend.com. From address can be your verified domain or onboarding@resend.dev for testing.
RESEND_API_KEY=
# RESEND_FROM_EMAIL=Password Reset <onboarding@resend.dev>

# PostHog (product analytics) – get key from https://us.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Custom MCP server url
RESTACK_ENGINE_MCP_ADDRESS=https://fb095f09f128.ngrok-free.app/mcp

# PhantomBuster (optional - LinkedIn activity monitor batch agent)
# PHANTOMBUSTER_API_KEY=
# PHANTOMBUSTER_ACTIVITY_EXTRACTOR_PHANTOM_ID=9136

# Next.js Server Actions – set when self-hosting or running multiple instances to avoid "Failed to find Server Action".
# Must be base64, 16/24/32 bytes decoded. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set at build time (e.g. in CI or before `pnpm build`).
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Slack Bot (optional - see apps/slack-bot/SETUP.md)
# Note: SLACK_BOT_TOKEN must also be set on the backend for response streaming.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...
# DEFAULT_WORKSPACE_ID=...
# SLACK_DEFAULT_CHANNEL_ID=...
